# ─────────────────────────────────────────────────────────────
# VisionVoice configuration. Copy to `.env` and edit.
# All variables are prefixed with VV_.
# ─────────────────────────────────────────────────────────────

# Which model backend to use: anthropic | ollama | offline | mock
#   offline  -> fully on-device, no API, no network (recommended for Raspberry Pi 5)
#   anthropic-> Claude cloud (best quality)   ollama -> local LLM/VLM   mock -> tests
VV_PROVIDER=offline

# --- Anthropic (cloud) ---
VV_ANTHROPIC_API_KEY=
VV_ANTHROPIC_MODEL=claude-sonnet-5
VV_ANTHROPIC_VISION_MODEL=claude-sonnet-5

# --- Ollama (local) ---
VV_OLLAMA_HOST=http://localhost:11434
VV_OLLAMA_TEXT_MODEL=llama3.1
VV_OLLAMA_VISION_MODEL=llava

# --- Perception ---
VV_CAMERA_INDEX=0
VV_YOLO_MODEL=yolov8n.pt
VV_YOLO_CONF=0.35

# --- Speech ---
# tts engine: gtts | pyttsx3 | print   (pyttsx3 = offline on-device speech, good for Pi)
VV_TTS_ENGINE=pyttsx3
# stt engine: whisper | google | text  (whisper = offline on-device speech-to-text)
VV_STT_ENGINE=whisper
# Spoken output languages (comma separated ISO codes): en, ta (Tamil), ml (Malayalam)
VV_LANGUAGES=en,ta,ml
