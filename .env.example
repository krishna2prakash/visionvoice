# ─────────────────────────────────────────────────────────────
# VisionVoice configuration. Copy to `.env` and edit.
# All variables are prefixed with VV_.
# ─────────────────────────────────────────────────────────────

# Which model backend to use: anthropic | ollama | mock
VV_PROVIDER=mock

# --- Anthropic (cloud) ---
VV_ANTHROPIC_API_KEY=
VV_ANTHROPIC_MODEL=claude-sonnet-5
VV_ANTHROPIC_VISION_MODEL=claude-sonnet-5

# --- Ollama (local) ---
VV_OLLAMA_HOST=http://localhost:11434
VV_OLLAMA_TEXT_MODEL=llama3.1
VV_OLLAMA_VISION_MODEL=llava

# --- Perception ---
VV_CAMERA_INDEX=0
VV_YOLO_MODEL=yolov8n.pt
VV_YOLO_CONF=0.35

# --- Speech ---
# tts engine: gtts | pyttsx3 | print   (print = log only, for headless/tests)
VV_TTS_ENGINE=print
# stt engine: whisper | google | text  (text = keyboard input)
VV_STT_ENGINE=text
# Spoken output languages (comma separated ISO codes): en, ta (Tamil), ml (Malayalam)
VV_LANGUAGES=en,ta,ml
